# Notion integration for the "Upcoming Performances" section.
# Copy to .env.local for local dev, and add both to the Vercel project's
# Environment Variables for production.

# Internal integration secret from https://www.notion.so/my-integrations (starts with "ntn_")
NOTION_API_KEY=

# The Concerts database ID: the 32-char hash in the database URL,
# e.g. notion.so/<workspace>/<THIS_PART>?v=...
NOTION_CONCERTS_DB_ID=
